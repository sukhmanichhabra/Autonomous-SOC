# ============================================================================
# Autonomous Cybersecurity SOC Agent — Environment Variables
# ============================================================================
#
# Copy this file to .env and fill in your actual values before running.
# You can also set these variables directly in your shell environment.
#
# CRITICAL: Never commit the .env file with real credentials to version
# control. Always keep sensitive values in .env (which should be .gitignore'd).
#

# ─────────────────────────────────────────────────────────────────────────
# LLM & API Configuration (REQUIRED)
# ─────────────────────────────────────────────────────────────────────────

# Groq API Key for LLM access
# Get your API key from: https://console.groq.com
# This is REQUIRED for the threat analysis and response agents to function
GROQ_API_KEY=your_groq_api_key_here

# Main LLM model for threat analysis and response generation
# Default: llama-3.3-70b-versatile (recommended for 70B reasoning)
# Other options: llama-3.1-70b-versatile, mixtral-8x7b-32768
GROQ_MODEL_MAIN=llama-3.3-70b-versatile

# Legacy model variable used by CLI and some helper scripts
GROQ_MODEL=llama-3.3-70b-versatile

# Lightweight LLM model for CVE re-ranking and filtering
# Default: llama-3.1-8b-instant (fast, low token usage)
GROQ_MODEL_RANKER=llama-3.1-8b-instant


# ─────────────────────────────────────────────────────────────────────────
# Database Configuration (PostgreSQL)
# ─────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string for LangGraph checkpointer and pgvector RAG
# Format: postgresql://user:password@host:port/dbname
# Default: postgresql://soc_user:soc_password@localhost:5432/soc_agent
# 
# Setup: Run `python my-ai-soc-agent/init_db.py` to create the database
DATABASE_URL=postgresql://soc_user:soc_password@localhost:5432/soc_agent

# Primary DB URL used by app/agents/checkpointer (recommended)
# Set this to the same value as DATABASE_URL unless you need override behavior
DB_URL=postgresql://soc_user:soc_password@localhost:5432/soc_agent

# Optional split database credentials (for deployment templates / compose)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=soc_agent
DB_USER=soc_user
DB_PASSWORD=soc_password

# Host-side Streamlit dashboard port when running via Docker Compose
# Container always listens on 8501 internally.
DASHBOARD_PORT=8501

# [DEPRECATED] Legacy ChromaDB path (for backwards compatibility)
# THREAT_INTEL_DB_PATH=./my-ai-soc-agent/vector_db/chroma_data


# ─────────────────────────────────────────────────────────────────────────
# Scanning & Reconnaissance Configuration
# ─────────────────────────────────────────────────────────────────────────

# Path to nmap executable
# Leave blank to auto-detect from PATH
# Example (macOS with Homebrew): /usr/local/bin/nmap
# Example (Linux): /usr/bin/nmap
NMAP_PATH=nmap

# Timeout in seconds for nmap scans
# Increase this for slow networks or large IP ranges
NMAP_TIMEOUT=300


# ─────────────────────────────────────────────────────────────────────────
# Execution & Response Modes
# ─────────────────────────────────────────────────────────────────────────

# Dry-run mode: set to "true" to simulate remediation without executing
# Set to "false" to enable LIVE execution (dangerous, requires approval)
# Default: true (safe mode)
DRY_RUN=true

# Default target used by Streamlit and CLI when no target is passed
SCAN_TARGET=127.0.0.1

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
LOG_LEVEL=INFO


# ─────────────────────────────────────────────────────────────────────────
# Firewall API Configuration
# ─────────────────────────────────────────────────────────────────────────

# Base URL for firewall control API
# Default: http://127.0.0.1:5001 (local simulated API)
# Example (production): https://firewall.company.com/api
FIREWALL_API_URL=http://127.0.0.1:5001

# Endpoint path for blocking IPs on firewall API
# Default: /api/v1/firewall/block-ip
FIREWALL_BLOCK_PATH=/api/v1/firewall/block-ip

# Bearer token for firewall API authentication (optional)
# Leave blank if the API doesn't require authentication
# Example: FIREWALL_API_TOKEN=sk_firewall_abc123xyz789
FIREWALL_API_TOKEN=

# Timeout in seconds for firewall API calls
# Default: 10
FIREWALL_API_TIMEOUT=10


# ─────────────────────────────────────────────────────────────────────────
# EDR (Endpoint Detection & Response) API Configuration
# ─────────────────────────────────────────────────────────────────────────

# Base URL for EDR API
# Default: http://127.0.0.1:5002 (local simulated API)
# Example (production): https://edr.company.com/api
# Supported: CrowdStrike, Microsoft Defender, Sentinel One, Elastic, etc.
EDR_API_URL=http://127.0.0.1:5002

# Endpoint path for host isolation on EDR API
# Default: /api/v1/edr/isolate-host
EDR_ISOLATE_PATH=/api/v1/edr/isolate-host

# Bearer token for EDR API authentication (optional)
# Leave blank if the API doesn't require authentication
# Example: EDR_API_TOKEN=sk_edr_def456uvw234
EDR_API_TOKEN=

# Timeout in seconds for EDR API calls
# Default: 10
EDR_API_TIMEOUT=10


# ─────────────────────────────────────────────────────────────────────────
# Defense API Configuration (Simulated Local API)
# ─────────────────────────────────────────────────────────────────────────

# Bearer token for simulated defense API (optional)
# Only needed if running simulated_defense_api.py with authentication
# Example: SIMULATED_DEFENSE_API_TOKEN=dev-token-12345
SIMULATED_DEFENSE_API_TOKEN=


# ─────────────────────────────────────────────────────────────────────────
# File & Directory Paths
# ─────────────────────────────────────────────────────────────────────────

# Directory for storing incident reports and artifacts
# Created automatically if it doesn't exist
# Default: ./my-ai-soc-agent/incidents
INCIDENTS_DIR=./my-ai-soc-agent/incidents

# Directory for application logs
# Created automatically if it doesn't exist
# Default: ./logs
LOGS_DIR=./logs


# ─────────────────────────────────────────────────────────────────────────
# Streamlit Configuration (app.py)
# ─────────────────────────────────────────────────────────────────────────

# Streamlit theme: light or dark
# Default: dark
STREAMLIT_THEME=dark

# Max file upload size in MB for Streamlit
# Default: 200
STREAMLIT_MAX_UPLOAD_SIZE=200


# ─────────────────────────────────────────────────────────────────────────
# Optional: SSH Response Automation
# ─────────────────────────────────────────────────────────────────────────
# Uncomment these if you want to enable automated SSH-based isolation commands

# Enable optional SSH fallback actions in response automation
RESPONSE_ENABLE_SSH_ACTIONS=false

# Remote command execution target used by the action executor
TARGET_HOST=192.168.1.10
TARGET_USER=soc-operator
SSH_KEY_PATH=/Users/you/.ssh/id_ed25519

# Safety override for explicitly allowing commands to run on the local host
ALLOW_LOCAL_EXECUTION=false

# SSH server hostname/IP for remote response execution
# RESPONSE_SSH_HOST=192.168.1.1

# SSH port (default: 22)
# RESPONSE_SSH_PORT=22

# SSH username for authentication
# RESPONSE_SSH_USER=admin

# SSH password (optional, use key if possible)
# RESPONSE_SSH_PASSWORD=

# Path to SSH private key file
# Example: /home/user/.ssh/id_rsa
# RESPONSE_SSH_KEY_PATH=

# SSH command template for host isolation
# Supports {target_ip} placeholder
# Example: iptables -A INPUT -s {target_ip} -j DROP
# RESPONSE_SSH_ISOLATION_COMMAND=


# ─────────────────────────────────────────────────────────────────────────
# Optional: Zero Trust & Advanced Security Configuration
# ─────────────────────────────────────────────────────────────────────────

# SIEM/Log aggregation endpoint for security events
# Example: https://siem.company.com/api/events
# SIEM_API_URL=

# SIEM API authentication token
# SIEM_API_TOKEN=

# Threat intelligence feed URLs (comma-separated)
# Used to supplement the local ChromaDB store
# Examples:
#   - https://otx.alienvault.com/api/v1/pulses/subscribed
#   - https://www.abuse.ch/feeds/
# THREAT_INTEL_FEEDS=

# Slack webhook for incident notifications (optional)
# Get URL from: https://api.slack.com/messaging/webhooks
# Example: https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXX
# SLACK_WEBHOOK_URL=

# PagerDuty integration key for on-call escalation (optional)
# PAGERDUTY_INTEGRATION_KEY=


# ═════════════════════════════════════════════════════════════════════════
# Quick Start Examples
# ═════════════════════════════════════════════════════════════════════════
#
# Development (Local Simulation):
#   GROQ_API_KEY=your_groq_key
#   DRY_RUN=true
#   (Use default localhost URLs)
#
# Production (Live Response):
#   GROQ_API_KEY=your_groq_key
#   DRY_RUN=false
#   FIREWALL_API_URL=https://firewall.company.com/api
#   FIREWALL_API_TOKEN=your_firewall_token
#   EDR_API_URL=https://edr.company.com/api
#   EDR_API_TOKEN=your_edr_token
#   SLACK_WEBHOOK_URL=your_webhook_url
#
#
# ═════════════════════════════════════════════════════════════════════════
# Security Best Practices
# ═════════════════════════════════════════════════════════════════════════
#
# 1. NEVER commit .env with real credentials to git
#    Use: git add .env.example  (keep this committed)
#         git add .gitignore    (add .env to ignore rules)
#
# 2. Use a secrets manager in production:
#    - AWS Secrets Manager
#    - HashiCorp Vault
#    - Azure Key Vault
#    - Kubernetes Secrets
#
# 3. Rotate API keys regularly (every 90 days)
#
# 4. Use strong, unique tokens for each service
#
# 5. Restrict API key permissions to least-privilege scope
#
# 6. Enable MFA on accounts that manage these credentials
#
# 7. Audit access logs for unauthorized API key usage
#
